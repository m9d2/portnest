{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PortNest",
  "version": "1.0.6",
  "identifier": "com.m9d2.portnest",
  "build": {
    "beforeDevCommand": "node scripts/prepare-tauri-sidecars.js",
    "beforeBuildCommand": "node scripts/prepare-tauri-sidecars.js",
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PortNest",
        "width": 420,
        "height": 780,
        "minWidth": 380,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#0f0f11"
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "createUpdaterArtifacts": true,
    "resources": {
      "../runtime-config.json": "runtime-config.json"
    },
    "externalBin": [
      "binaries/frpc",
      "binaries/gost"
    ],
    "icon": [
      "../build/icon.png",
      "../build/icon.icns",
      "../build/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCNzAwOEZEQkU3ODMxN0IKUldSN01YaSsvUWh3Sys2ZTBOYURmcU05RVQ1dmlCTDlySnJ5SFhmOE9EaUR0Zy9HbERGbDJzUVoK",
      "endpoints": [
        "https://github.com/m9d2/portnest/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
