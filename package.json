{
  "name": "portnest-mac-client",
  "version": "1.0.0",
  "description": "Electron macOS client for a dispatcher-managed SOCKS5 reverse tunnel",
  "main": "src/main.js",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js",
    "pack:mac": "electron-builder --mac dir",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:mac:release": "electron-builder --mac dmg zip --x64 --arm64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.m9d2.portnest",
    "productName": "PortNest",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "m9d2",
        "repo": "portnest"
      }
    ],
    "files": [
      "src/**/*",
      "runtime-config.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
